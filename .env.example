# ─────────────────────────────────────────────────────────────
# Zuest — environment template
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env file to GitHub.
# ─────────────────────────────────────────────────────────────

# The Discord Bot token for Zuest itself (the bot users interact with).
# Get it from: https://discord.com/developers/applications → your app → Bot → Reset Token
BOT_TOKEN=your_bot_token_here

# Comma-separated list of Discord user IDs allowed to use ;link, ;quest, ;questall, etc.
# Leave empty to allow anyone who DMs the bot to link their token (not recommended on public bots).
# Example: 111111111111111111,222222222222222222
ALLOWED_USER_IDS=

# The command prefix. Defaults to ";"
COMMAND_PREFIX=;

# AES-256 master key used to encrypt user tokens at rest in the SQLite DB.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left empty, tokens are stored in PLAINTEXT (very insecure — only for local testing).
TOKEN_ENCRYPTION_KEY=

# Path to the SQLite database file. Default: ./data/tokens.db
DATABASE_PATH=./data/tokens.db

# Discord API base URL (rarely changed)
DISCORD_API_BASE=https://discord.com/api/v9

# Show verbose debug logs in the console? true / false
DEBUG=false
